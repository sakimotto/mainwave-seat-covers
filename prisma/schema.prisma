generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, citext]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Product {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  description  String?
  nameTh       String?
  descriptionTh String?
  material     String?
  features     String[]
  image        String
  images       String[]
  category     String?
  vehicleLabel String?
  isSale       Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vehicleId    String?
  vehicle      Vehicle?        @relation(fields: [vehicleId], references: [id])
  variants     ProductVariant[]
  reviews      Review[]
  embedding    ProductEmbedding?
  fitments     Fitment[]

  @@index([slug])
}

model ProductVariant {
  id             String      @id @default(cuid())
  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color          String
  colorHex       String?
  size           String?
  sku            String      @unique
  price          Decimal     @db.Decimal(10, 2)
  originalPrice  Decimal?    @db.Decimal(10, 2)
  stock          Int         @default(0)
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([productId])
  @@index([sku])
}

model Vehicle {
  id     String         @id @default(cuid())
  make   String
  slug   String         @unique
  image  String
  models VehicleModel[]
  products Product[]
  fitments Fitment[]
  garage   CustomerVehicle[]

  @@index([slug])
}

model VehicleModel {
  id        String  @id @default(cuid())
  name      String
  slug      String
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, slug])
  @@index([vehicleId])
}

model Fitment {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  yearStart Int?
  yearEnd   Int?
  trim      String?
  notes     String?

  @@unique([productId, vehicleId, yearStart, yearEnd, trim])
  @@index([productId])
  @@index([vehicleId])
}

model Customer {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  password      String?
  referralCode  String?           @unique
  referredById  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  sessions      Session[]
  garage        CustomerVehicle[]
  creditEntries CreditEntry[]

  @@index([email])
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerVehicle {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  model      String?
  year       Int?
  nickname   String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CreditEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(10, 2)
  reason     String
  orderId    String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Cart {
  id         String     @id @default(cuid())
  customerId String?    @unique
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessionId  String?    @unique
  items      CartItem[]

  @@index([customerId])
  @@index([sessionId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int

  @@unique([cartId, variantId])
  @@index([cartId])
}

model Order {
  id               String      @id @default(cuid())
  customerId       String
  customer         Customer    @relation(fields: [customerId], references: [id])
  status           OrderStatus @default(PENDING)
  total            Decimal     @db.Decimal(10, 2)
  shippingName     String?
  shippingPhone    String?
  shippingAddress  String?
  shippingSuburb   String?
  shippingState    String?
  shippingPostcode String?
  shippingNotes    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  items            OrderItem[]

  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Decimal        @db.Decimal(10, 2)

  @@index([orderId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  name       String
  rating     Int
  text       String
  createdAt  DateTime @default(now())

  @@index([productId])
}

model BlogPost {
  id       String   @id @default(cuid())
  title    String
  slug     String   @unique
  excerpt  String
  content  String?
  image    String
  date     DateTime
  category String

  @@index([slug])
  @@index([category])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ProductEmbedding {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  content   String
  embedding Unsupported("vector(1536)")

  @@index([productId])
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  preferences String[]
  locale      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([email])
}
