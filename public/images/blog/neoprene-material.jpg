  <rect width="400" height="250" fill="url(#bg)"/>
  <circle cx="320" cy="60" r="40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <circle cx="340" cy="50" r="60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
  <text x="200" y="135" text-anchor="middle" font-size="16" font-family="Arial, sans-serif" font-weight="bold" fill="rgba(255,255,255,0.6)">neoprene-material</text>
